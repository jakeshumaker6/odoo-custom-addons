<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Smart button on customer form showing deposit count -->
    <record id="view_partner_form_deposit" model="ir.ui.view">
        <field name="name">res.partner.form.deposit</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_deposits"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-money"
                        invisible="deposit_count == 0">
                    <field name="deposit_count" widget="statinfo" string="Deposits"/>
                </button>
            </xpath>
        </field>
    </record>
</odoo>
