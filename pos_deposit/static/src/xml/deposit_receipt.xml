<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

    <!-- Add deposit header and footer to receipt -->
    <t t-name="pos_deposit.OrderReceipt" t-inherit="point_of_sale.OrderReceipt" t-inherit-mode="extension">
        <!-- Add CUSTOMER DEPOSIT header before the receipt content -->
        <xpath expr="//div[hasclass('pos-receipt')]" position="inside">
            <t t-if="order.is_deposit">
                <div class="deposit-receipt-header text-center mt-3 mb-2" style="order: -1;">
                    <div style="font-size: 1.5em; font-weight: bold; border: 2px solid black; padding: 8px;">
                        CUSTOMER DEPOSIT
                    </div>
                    <div class="mt-1" style="font-size: 1.1em;">
                        Ref: <t t-esc="order.deposit_reference || ('DEP-' + String(order.id).padStart(5, '0'))"/>
                    </div>
                </div>
            </t>
        </xpath>

        <!-- Add deposit footer disclaimer -->
        <xpath expr="//div[hasclass('pos-receipt')]" position="inside">
            <t t-if="order.is_deposit">
                <div class="deposit-receipt-footer text-center mt-3 pt-2" style="border-top: 1px dashed black;">
                    <div style="font-weight: bold;">NON-REFUNDABLE DEPOSIT</div>
                    <div class="small mt-1">This deposit does not expire.</div>
                    <div class="small">Present this receipt to redeem your deposit on a future purchase.</div>
                    <div class="small mt-1">
                        Customer: <t t-esc="order.partner_id?.name || ''"/>
                    </div>
                </div>
            </t>
        </xpath>
    </t>

</templates>
