<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

    <!-- Add "Change Shipping" button next to the Ship Later button -->
    <t t-inherit="point_of_sale.PaymentScreen" t-inherit-mode="extension">
        <xpath expr="//button[contains(@t-on-click, 'toggleShippingDatePicker')]" position="after">
            <button t-if="pos.config.ship_later and pos.config.shipengine_carrier_id and currentOrder.shipping_tier"
                    class="button btn btn-secondary btn-lg d-flex justify-content-between align-items-baseline w-100 lh-lg mt-1 highlight active text-action"
                    t-on-click="_fetchAndShowShippingRates">
                <span class="me-auto"><i class="fa fa-truck me-2"/>Change Shipping</span>
                <span>
                    <t t-if="currentOrder.shipping_tier === 'custom'">Custom</t>
                    <t t-elif="currentOrder.shipping_tier === 'express'">Express</t>
                    <t t-elif="currentOrder.shipping_tier === 'standard'">Standard</t>
                    <t t-elif="currentOrder.shipping_tier === 'economy'">Economy</t>
                    <t t-else=""><t t-esc="currentOrder.shipping_tier"/></t>
                    — $<t t-esc="(currentOrder.shipping_amount || 0).toFixed(2)"/>
                </span>
            </button>
        </xpath>
    </t>

</templates>
