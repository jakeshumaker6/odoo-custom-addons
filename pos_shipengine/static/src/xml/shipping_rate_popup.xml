<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

    <t t-name="pos_shipengine.ShippingRatePopup">
        <Dialog title="props.title" size="'md'">
            <div class="shipping-rate-popup p-3">
                <!-- Tier options -->
                <t t-if="props.tiers.length > 0">
                    <div class="d-flex flex-column gap-2 mb-3">
                        <t t-foreach="props.tiers" t-as="tier" t-key="tier.tier">
                            <button
                                class="btn btn-lg d-flex justify-content-between align-items-center w-100 p-3"
                                t-att-class="{
                                    'btn-primary': state.selectedTier === tier,
                                    'btn-outline-secondary': state.selectedTier !== tier
                                }"
                                t-on-click="() => this.selectTier(tier)">
                                <div class="text-start">
                                    <div class="fw-bold fs-5">
                                        <t t-esc="tierLabels[tier.tier] || tier.tier"/>
                                    </div>
                                    <div class="text-muted small">
                                        <t t-esc="tier.carrier_name"/>
                                        <t t-if="tier.service_type"> — <t t-esc="tier.service_type"/></t>
                                    </div>
                                    <div class="text-muted small">
                                        <t t-esc="tier.delivery_days"/> day<t t-if="tier.delivery_days !== 1">s</t>
                                        <t t-if="tier.estimated_delivery"> (est. <t t-esc="tier.estimated_delivery"/>)</t>
                                    </div>
                                </div>
                                <div class="fw-bold fs-4">
                                    <t t-esc="formatCurrency(tier.amount)"/>
                                </div>
                            </button>
                        </t>
                    </div>
                </t>

                <t t-if="props.tiers.length === 0">
                    <div class="alert alert-warning mb-3">
                        No carrier rates available for this destination. Enter a custom shipping amount below.
                    </div>
                </t>

                <!-- Divider -->
                <div class="d-flex align-items-center my-3">
                    <hr class="flex-grow-1"/>
                    <span class="px-3 text-muted">or</span>
                    <hr class="flex-grow-1"/>
                </div>

                <!-- Custom amount -->
                <button
                    class="btn btn-lg d-flex justify-content-between align-items-center w-100 p-3 mb-2"
                    t-att-class="{
                        'btn-primary': state.useCustom,
                        'btn-outline-secondary': !state.useCustom
                    }"
                    t-on-click="selectCustom">
                    <div class="fw-bold">Custom Shipping Amount</div>
                </button>

                <div t-if="state.useCustom" class="input-group input-group-lg mb-3">
                    <span class="input-group-text">$</span>
                    <input type="number" class="form-control"
                           placeholder="0.00" step="0.01" min="0"
                           t-model.number="state.customAmount"
                           t-ref="customInput"/>
                </div>

                <!-- Confirm button -->
                <div class="d-grid mt-3">
                    <button class="btn btn-primary btn-lg"
                            t-att-disabled="!canConfirm"
                            t-on-click="confirm">
                        Confirm Shipping
                    </button>
                </div>
            </div>
        </Dialog>
    </t>

</templates>
