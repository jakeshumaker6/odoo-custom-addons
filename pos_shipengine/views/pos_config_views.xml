<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="pos_config_view_form_shipengine" model="ir.ui.view">
        <field name="name">pos.config.form.shipengine</field>
        <field name="model">pos.config</field>
        <field name="inherit_id" ref="point_of_sale.pos_config_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='ship_later']" position="after">
                <field name="shipengine_carrier_id"
                       invisible="not ship_later"
                       required="ship_later"/>
            </xpath>
        </field>
    </record>
</odoo>
