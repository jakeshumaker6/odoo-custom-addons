<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Add ShipEngine carrier field to POS Settings under Ship Later -->
    <record id="res_config_settings_view_form_shipengine" model="ir.ui.view">
        <field name="name">res.config.settings.form.shipengine</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="point_of_sale.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='pos_warehouse_id']" position="after">
                <field name="pos_shipengine_carrier_id"
                       invisible="not pos_ship_later"
                       required="pos_ship_later"/>
            </xpath>
        </field>
    </record>
</odoo>
