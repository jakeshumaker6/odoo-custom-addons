<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Cron: Sync Products from WooCommerce -->
    <record id="ir_cron_wc_product_sync" model="ir.cron">
        <field name="name">WooCommerce: Sync Products</field>
        <field name="model_id" ref="model_wc_backend"/>
        <field name="state">code</field>
        <field name="code">model._cron_sync_products()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">hours</field>
        <field name="active">True</field>
    </record>

</odoo>
