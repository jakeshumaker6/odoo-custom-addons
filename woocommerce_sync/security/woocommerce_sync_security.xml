<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="group_wc_user" model="res.groups">
        <field name="name">WooCommerce User</field>
    </record>

    <record id="group_wc_manager" model="res.groups">
        <field name="name">WooCommerce Manager</field>
        <field name="implied_ids" eval="[(4, ref('woocommerce_sync.group_wc_user'))]"/>
        <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
    </record>

</odoo>
