<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Add JustiFi payment methods field to Invoice form -->
    <record id="view_move_form_justifi" model="ir.ui.view">
        <field name="name">account.move.form.justifi</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <!-- Add payment methods field in the invoice tab, near payment terms -->
            <xpath expr="//field[@name='invoice_payment_term_id']" position="after">
                <field name="justifi_payment_methods"
                       string="JustiFi Payment Options"
                       widget="radio"
                       invisible="move_type not in ('out_invoice', 'out_refund')"/>
            </xpath>
        </field>
    </record>

</odoo>
