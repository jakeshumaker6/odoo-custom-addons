<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_delivery_carrier_form_shipengine" model="ir.ui.view">
        <field name="name">delivery.carrier.form.shipengine</field>
        <field name="model">delivery.carrier</field>
        <field name="inherit_id" ref="delivery.view_delivery_carrier_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='provider_details']" position="after">
                <group string="ShipEngine Configuration"
                       invisible="delivery_type != 'shipengine'"
                       name="shipengine_config">
                    <field name="shipengine_api_key" password="True"/>
                    <field name="shipengine_carrier_ids"
                           placeholder="e.g., se-123456,se-789012 (leave blank for all)"/>
                    <field name="shipengine_default_weight_oz"/>
                    <field name="shipengine_default_package_code"/>
                    <field name="shipengine_label_format"/>
                    <field name="shipengine_excluded_service_codes"
                           placeholder="e.g., usps_media_mail,usps_library_mail"/>
                    <field name="shipengine_excluded_package_types"
                           placeholder="e.g., flat_rate_envelope,small_flat_rate_box"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
